DATABASE_URL="postgresql://dam:dam@localhost:5433/dam?schema=public"
PORT=4000
# Primary browser origin for CORS + cookies. In development the API also allows the
# localhost ↔ 127.0.0.1 twin on the same port (e.g. http://127.0.0.1:3002).
WEB_ORIGIN="http://localhost:3002"
SESSION_DAYS=14
# Any OTP works in development when set; otherwise use this code
DEV_OTP="123456"

# Razorpay test keys from dashboard (https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
# Optional: Webhooks → signing secret
RAZORPAY_WEBHOOK_SECRET=""
