# Browser-visible API base (must be HTTPS in production).
# Vercel: Production + Preview — set this to your publicly reachable API origin if the
# API is a separate deployment (omit trailing slash; path must include /api).
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# If visitors see Vercel's login / "Authentication Required" page when opening your URL,
# that is Deployment Protection — not this app. Either in the dashboard: Project →
# Settings → Deployment Protection, or from the repo root (with a Vercel token):
#   VERCEL_TOKEN=... VERCEL_PROJECT=your-project-name node scripts/disable-vercel-deployment-protection.mjs
# Ensure the linked Git project's Root Directory is apps/web for this monorepo.
