# Browser-visible API base (must be HTTPS in production).
# Vercel: Production + Preview — set this to your publicly reachable API origin if the
# API is a separate deployment (omit trailing slash; path must include /api).
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# If visitors must log in to Vercel first when opening your .vercel.app link, that is
# Vercel Deployment Protection — not controlled by Next.js source.
#
# Dashboard: Project → Settings → Deployment Protection → turn OFF "Vercel Authentication"
# and any password/IP protection on the deployments you share, or shrink scope so
# Production URLs are open. Preview branch URLs stay gated by default unless you change that.
#
# Or from repo root with a token (https://vercel.com/account/tokens):
#   VERCEL_TOKEN=... VERCEL_PROJECT=your-project-name npm run vercel:disable-deployment-protection
# Team-owned project also set VERCEL_TEAM_ID or VERCEL_TEAM_SLUG.
#
# Ensure the linked Git project's Root Directory is apps/web for this monorepo.
